# ─────────────────────────────────────────────
#  BT Studio AI Workspace — Backend Environment
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL="postgresql://bt_user:bt_pass@localhost:5432/bt_studio?schema=public"

# Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS — comma-separated origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
#  AI Provider routing
# ─────────────────────────────────────────────
# Comma-separated priority list used when an AITool has no explicit provider,
# or when a configured provider isn't available. Defaults to dispatcher,comfyui,mock.
AI_PROVIDER_PRIORITY="dispatcher,comfyui,mock"

# ─────────────────────────────────────────────
#  comfy-dispatcher (external HTTP service)
#  - POST /jobs       → submit a ComfyUI workflow + image URL
#  - GET  /jobs/{id}  → poll status until done/failed
#  Leave DISPATCHER_BASE_URL empty to fall back to ComfyUI/Mock.
# ─────────────────────────────────────────────
DISPATCHER_BASE_URL=""
DISPATCHER_API_KEY=""
DISPATCHER_CALLBACK_URL=""

# Workflow JSON for IMAGE_UPSCALE (used by Dispatcher + ComfyUI direct).
# Provide ONE of:
#   COMFYUI_UPSCALE_WORKFLOW_JSON  — inline raw JSON string
#   COMFYUI_UPSCALE_WORKFLOW_PATH  — absolute path to a .json file
COMFYUI_UPSCALE_WORKFLOW_JSON=""
COMFYUI_UPSCALE_WORKFLOW_PATH=""

# AI Tool API Keys (add your providers here)
OPENAI_API_KEY=""
STABILITY_API_KEY=""
REPLICATE_API_TOKEN=""

# File Storage — local (dev) or S3-compatible (production)
# For production, use Cloudflare R2 (or AWS S3) by setting STORAGE_DRIVER=s3
STORAGE_DRIVER="local"               # local | s3
STORAGE_LOCAL_PATH="./uploads"
STORAGE_MAX_FILE_SIZE_MB=200

# S3 / Cloudflare R2 (required when STORAGE_DRIVER=s3)
# STORAGE_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
# STORAGE_BUCKET="bt-studio-assets"
# STORAGE_REGION="auto"
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
# STORAGE_PUBLIC_BASE_URL="https://pub-<token>.r2.dev"  # public R2 bucket URL or CDN prefix
