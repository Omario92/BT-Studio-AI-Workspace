# ─────────────────────────────────────────────
#  BT Studio AI Workspace — Backend Environment
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL="postgresql://bt_user:bt_pass@localhost:5432/bt_studio?schema=public"

# Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS — comma-separated origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# AI Tool API Keys (add your providers here)
OPENAI_API_KEY=""
STABILITY_API_KEY=""
REPLICATE_API_TOKEN=""

# File Storage (local path or S3-compatible)
STORAGE_DRIVER="local"               # local | s3
STORAGE_LOCAL_PATH="./uploads"
# S3_BUCKET=""
# S3_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
