// ─────────────────────────────────────────────
//  BT Studio AI Workspace — Prisma Schema
//  Production model — all enums and relations
// ─────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────

enum Role {
  ADMIN
  PRODUCER
  ARTIST
  ART_DIRECTOR
  AI_ENGINEER
  REVIEWER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  WIP
  COMPLETED
  ARCHIVED
}

enum AssetStatus {
  DRAFT
  WIP
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  GENERATING
  FAILED
  ARCHIVED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  IMAGE_GENERATION
  IMAGE_UPSCALE
  IMAGE_EDIT
  VARIATION
  REMOVE_BACKGROUND
  RELIGHT
  VIDEO_GENERATION
  VOICE_GENERATION
  BATCH_GENERATION
  CUSTOM
}

enum ToolCategory {
  IMAGE
  VIDEO
  AUDIO
  SPACES
  THREE_D
}

enum ReviewDecision {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

// ─── User ─────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(ARTIST)
  avatarUrl    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedProjects  Project[]        @relation("ProjectOwner")
  projectMembers ProjectMember[]
  assets         Asset[]          @relation("AssetCreator")
  jobs           AIJob[]
  comments       Comment[]
  assignments    Assignment[]
  activityLogs   ActivityLog[]
  reviews        Review[]

  @@map("users")
}

// ─── Project ──────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  client      String
  description String?
  status      ProjectStatus @default(ACTIVE)
  progress    Int           @default(0)
  tone        String?
  isPinned    Boolean       @default(false)
  ownerId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner        User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members      ProjectMember[]
  folders      Folder[]
  assets       Asset[]
  jobs         AIJob[]
  assignments  Assignment[]
  activityLogs ActivityLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role     @default(ARTIST)
  joinedAt  DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Folder ───────────────────────────────────

model Folder {
  id        String   @id @default(cuid())
  name      String
  projectId String
  parentId  String?
  depth     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children  Folder[] @relation("FolderChildren")
  assets    Asset[]

  @@map("folders")
}

// ─── Asset ────────────────────────────────────

model Asset {
  id             String      @id @default(cuid())
  name           String
  fileUrl        String?
  mimeType       String?
  fileSizeBytes  Int?
  status         AssetStatus @default(DRAFT)
  currentVersion Int         @default(1)
  projectId      String
  folderId       String?
  creatorId      String
  jobId          String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder       Folder?        @relation(fields: [folderId], references: [id])
  creator      User           @relation("AssetCreator", fields: [creatorId], references: [id])
  job          AIJob?         @relation(fields: [jobId], references: [id])
  versions     AssetVersion[]
  comments     Comment[]
  activityLogs ActivityLog[]

  @@map("assets")
}

// ─── Asset Version ────────────────────────────
// Every generation / edit / upscale output creates a new AssetVersion.
// Never overwrites the Asset or a prior version.

model AssetVersion {
  id            String      @id @default(cuid())
  assetId       String
  versionNumber Int
  fileUrl       String?
  mimeType      String?
  fileSizeBytes Int?
  status        AssetStatus @default(DRAFT)
  jobId         String?
  params        Json?
  notes         String?
  createdById   String?
  createdAt     DateTime    @default(now())

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  job     AIJob?  @relation(fields: [jobId], references: [id])
  reviews Review[]

  @@unique([assetId, versionNumber])
  @@map("asset_versions")
}

// ─── Review ───────────────────────────────────
// Business rules (enforced in service layer):
//   REJECTED             → comment is required
//   REVISION_REQUESTED   → comment is required
//   APPROVED             → comment is optional
// Every review action creates an ActivityLog entry.

model Review {
  id         String         @id @default(cuid())
  versionId  String
  reviewerId String
  decision   ReviewDecision
  comment    String?
  createdAt  DateTime       @default(now())

  version  AssetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewer User         @relation(fields: [reviewerId], references: [id])

  @@map("reviews")
}

// ─── AI Job ───────────────────────────────────

model AIJob {
  id          String    @id @default(cuid())
  name        String?
  type        JobType
  status      JobStatus @default(QUEUED)
  progress    Int       @default(0)
  queueJobId  String?
  projectId   String
  userId      String
  toolId      String?
  params      Json
  result      Json?
  errorMsg    String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  tool          AITool?        @relation(fields: [toolId], references: [id])
  assets        Asset[]
  assetVersions AssetVersion[]
  activityLogs  ActivityLog[]

  @@map("ai_jobs")
}

// ─── AI Tool Registry ─────────────────────────

model AITool {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  category    ToolCategory @default(IMAGE)
  icon        String?
  badge       String?
  badgeKind   String?
  provider    String?
  modelId     String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  config      Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  jobs AIJob[]

  @@map("ai_tools")
}

// ─── Template ─────────────────────────────────

model Template {
  id           String   @id @default(cuid())
  name         String
  category     String
  description  String?
  thumbnailUrl String?
  tags         String[]
  isActive     Boolean  @default(true)
  usageCount   Int      @default(0)
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("templates")
}

// ─── Comment ──────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  body      String
  assetId   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset  Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@map("comments")
}

// ─── Assignment ───────────────────────────────

model Assignment {
  id         String    @id @default(cuid())
  title      String
  dueAt      DateTime?
  isDone     Boolean   @default(false)
  projectId  String?
  assigneeId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project  Project? @relation(fields: [projectId], references: [id])
  assignee User     @relation(fields: [assigneeId], references: [id])

  @@map("assignments")
}

// ─── Activity Log ─────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  detail     String?
  userId     String
  projectId  String?
  assetId    String?
  jobId      String?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  asset   Asset?   @relation(fields: [assetId], references: [id])
  job     AIJob?   @relation(fields: [jobId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
